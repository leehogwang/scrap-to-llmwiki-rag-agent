# AI Backend Selection
# Set to 'true' to use codex auth (ChatGPT Plus/Pro subscription quota)
# Set to 'false' or leave empty to use standard OpenAI API key
USE_CODEX_AUTH=false
CODEX_AUTH_MODEL=gpt-5.4-mini

# OpenAI API Key (required when USE_CODEX_AUTH=false)
# Not required when USE_CODEX_AUTH=true
OPENAI_API_KEY=

# Notion Integration
NOTION_API_KEY=
NOTION_SCRAP_DATABASE_ID=
NOTION_WIKI_ROOT_PAGE_ID=

# Model Configuration
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODERATION_MODEL=omni-moderation-latest
